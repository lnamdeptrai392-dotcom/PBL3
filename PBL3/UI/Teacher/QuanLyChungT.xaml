<Window x:Class="PBL3a.UI.Teacher.QuanLyChungT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuanLyChungT"
        Width="1000"
        Height="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#2C4E62">

    <Grid>
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#2C4E62"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="55"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#3E6A83"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Background="#2C4E62">

            <Grid Height="120">
                <Image Width="103"
                       Height="91"
                       Stretch="Fill"
                       Source="/Resources/2026.png"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Grid>

            <Button x:Name="btnInfo"
                    Content="Thông tin cá nhân"
                    Click="btnInfo_Click"/>

            <Button x:Name="btnSchedule"
                    Content="Thời khóa biểu"
                    Click="btnSchedule_Click"/>

            <Button x:Name="btnScore"
                    Content="Nhập điểm"
                    Click="btnScore_Click"/>

            <Button x:Name="btnSalary"
                    Content="Lương"
                    Click="btnSalary_Click"/>

            <Button x:Name="btnExit"
                    Content="Đăng xuất"
                    Click="btnExit_Click"/>
        </StackPanel>

        <ContentControl x:Name="panelMain"
                        Grid.Column="1"
                        Background="White"/>
    </Grid>
</Window>