<UserControl x:Class="PBL3a.UI.AdminDD.DiemDanh"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="QUẢN LÝ ĐIỂM DANH"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="Chọn lớp" VerticalAlignment="Center" Margin="0 0 10 0"/>

            <ComboBox x:Name="cboLopHoc"
                      Width="200"
                      Height="32"
                      Margin="0 0 30 0"/>

            <TextBlock Text="Ngày" VerticalAlignment="Center" Margin="0 0 10 0"/>

            <DatePicker x:Name="date"
                        Width="150"
                        Height="32"
                        SelectedDateChanged="date_ValueChanged"
                        Margin="0 0 30 0"/>

            <Button x:Name="btnTimKiem"
                    Content="🔍 Tìm kiếm"
                    Width="130"
                    Height="34"
                    Click="btnTimKiem_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgvDiemDanh"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeaderWidth="0"
                  SelectionMode="Single"
                  Margin="40 10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã HS"
                                    Binding="{Binding AccountID}"
                                    IsReadOnly="True"
                                    Width="*"/>

                <DataGridTextColumn Header="Tên học sinh"
                                    Binding="{Binding StudentName}"
                                    IsReadOnly="True"
                                    Width="2*"/>

                <DataGridComboBoxColumn Header="Trạng thái"
                                        SelectedItemBinding="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="{x:Type sys:String}">
                            <sys:String>Có mặt</sys:String>
                            <sys:String>Vắng</sys:String>
                            <sys:String>Muộn</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridTextColumn Header="Ghi chú"
                                    Binding="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button x:Name="btnSave"
                    Content="Lưu điểm danh"
                    Width="180"
                    Height="40"
                    Margin="20 0"
                    Background="#5D9CB3"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="btnSave_Click"/>

            <Button x:Name="btnExit"
                    Content="Thoát"
                    Width="130"
                    Height="40"
                    Margin="20 0"
                    Background="#5D9CB3"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="btnExit_Click"/>
        </StackPanel>
    </Grid>
</UserControl>