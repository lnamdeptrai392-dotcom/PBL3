<Window x:Class="PBL3a.UI.AdminTC.QuanLyChungTC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuanLyChungTC"
        Width="1000"
        Height="500"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Left" 
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263f60"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="84"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel
                    Grid.Column="0"
                    Background="#FF263F60" Grid.RowSpan="2">
            <Border Background="#263f60" Height="80">
                <TextBlock Text="EduCore"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
            </Border>

            <Expander Header="Quản lý Đối tượng"
                  Foreground="White" 
                  FontSize="14"
                  FontWeight="SemiBold"
                  BorderThickness="0"
                  Margin="0,5,0,0">
                <StackPanel Margin="20,5,0,5">
                    <Button x:Name="btnDshs"
                Content="   Danh sách học sinh" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnDshs_Click"/>
                    <Button x:Name="btnDsgv"
                Content="   Danh sách giáo viên" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnDsgv_Click"/>
                    

                </StackPanel>
            </Expander>

            <Expander Header="Nghiệp vụ thu - chi"
                  Foreground="White" 
                  FontSize="14"
                  FontWeight="SemiBold"
                  BorderThickness="0"
                  Margin="0,5,0,0">
                <StackPanel Margin="20,5,0,5">
                    <Button x:Name="btnThuHP"
                Content="   Thu học phí" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnThuHP_Click"/>
                    <Button x:Name="btnLuong"
                Content="   Chi trả lương" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnLuong_Click"/>
                    <Button x:Name="btnKhac"
                Content="   Khoản thu/chi khác" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnKhac_Click"/>

                </StackPanel>
            </Expander>

            <Expander Header="Thống kê và Báo cáo"
                  Foreground="White" 
                  FontSize="14"
                  FontWeight="SemiBold"
                  BorderThickness="0"
                  Margin="0,5,0,0">
                            <StackPanel Margin="20,5,0,5">
                                <Button x:Name="btnLshd"
                Content="   Lịch sử hóa đơn" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnLshd_Click"/>
                                <Button x:Name="btnProfit"
                Content="   Báo cáo lợi nhuận" 
                Style="{StaticResource MenuButtonStyle}"
                Click="btnProfit_Click"/>


                </StackPanel>
            </Expander>

            
            <Button x:Name="btnExit"
                    Content="Đăng Xuất"
                    Click="btnExit_Click"
                    Foreground="White" 
                    FontSize="14"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Margin="0,5,0,0"
                    Background="#FF263F60"/>
        </StackPanel>

        <ContentControl x:Name="paDesktop"
                        Grid.Column="1"
                        Background="White" Grid.RowSpan="2"/>
    </Grid>
</Window>