<UserControl x:Class="PBL3a.UI.AdminTC.LuongGV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White"
             Height="500" Width="1000">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="288"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="Mã Giáo viên:"
                   VerticalAlignment="Center"
                   FontSize="15" Height="20"/>

        <ComboBox x:Name="cbbMGV" Grid.Column="1"
                  IsEditable="True"
                  VerticalAlignment="Center"
                  SelectionChanged="cbbMGV_SelectionChanged"
                  KeyUp="cbbMGV_KeyUp" Height="46"/>
        <TextBlock Grid.Column="2"
                   Text="Tên Giáo viên:"
                   VerticalAlignment="Center"
                   FontSize="15" HorizontalAlignment="Center" Height="20" Width="92"/>
        <TextBox x:Name="tbTL"
                 Grid.Row="0" Grid.Column="3"
                 IsReadOnly="True"  Margin="0,12,0,12"/>
        <TextBlock Grid.Row="1" Grid.Column="0"
                   FontSize="15"
                   Text="Tháng:"
                   VerticalAlignment="Center" Height="20"/>

        <ComboBox x:Name="cbbThang"
                  Grid.Row="1" Grid.Column="1" BorderBrush="White" Foreground="Black" Margin="0,10,0,10">
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
            <ComboBoxItem Content="6"/>
            <ComboBoxItem Content="7"/>
            <ComboBoxItem Content="8"/>
            <ComboBoxItem Content="9"/>
            <ComboBoxItem Content="10"/>
            <ComboBoxItem Content="11"/>
            <ComboBoxItem Content="12"/>
        </ComboBox>

        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="15"  Text="Năm:"
                   VerticalAlignment="Center" HorizontalAlignment="Center" Height="20" Width="36"/>

        <TextBox x:Name="txtNam"  Grid.Row="1" Grid.Column="3" Margin="0,10,0,10"/>

        <DataGrid x:Name="dataGridView1"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Grid.ColumnSpan="5" Margin="0,23,10,77" Grid.RowSpan="2" HorizontalAlignment="Center">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Lương" Binding="{Binding LuongID}" Width="80"/>
                <DataGridTextColumn Header="Lương tháng" Binding="{Binding SalaryMonth}" Width="80"/>
                <DataGridTextColumn Header="Số lớp dạy" Binding="{Binding SoLopDay}" Width="90"/>
                <DataGridTextColumn Header="Số buổi dạy" Binding="{Binding SoBuoiDay}" Width="90"/>
                <DataGridTextColumn Header="Lương cơ bản" Binding="{Binding LuongCoBan, StringFormat={}{0:N0} VNĐ}" Width="100"/>
                <DataGridTextColumn Header="Thưởng" Binding="{Binding Thuong}" Width="70"/>
                <DataGridTextColumn Header="Phạt" Binding="{Binding Phat}" Width="70"/>
                <DataGridTextColumn Header="Tổng lương" Binding="{Binding TongLuong, StringFormat={}{0:N0} VNĐ}" Width="120"/>
                <DataGridTextColumn Header="Ngày thanh toán" Binding="{Binding NgayThanhToan}" Width="120"/>
                <DataGridTemplateColumn Header="Trạng Thái" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TrangThai}" VerticalAlignment="Center" Margin="5,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding TrangThai, UpdateSourceTrigger=PropertyChanged}" 
                                      SelectedValuePath="Content" 
      IsDropDownOpen="True">
                                <ComboBoxItem Content="Chưa thanh toán"/>
                                <ComboBoxItem Content="Đã thanh toán"/>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="btSetL"
                Grid.Row="3"
                Grid.Column="1"
                Content="Tính toán lương"
                Background="#5D9CB3"
                Foreground="White"
                Click="btSetL_Click" Margin="113,42,0,10" HorizontalAlignment="Left" Width="131"/>
        <Button x:Name="btnSave"
                Grid.Row="3"
                Grid.Column="2"
                Content="Lưu thay đổi"
                Background="#5D9CB3"
                Foreground="White"
                Click="btnSave_Click"
                Margin="62,42,0,10" HorizontalAlignment="Left" Width="131" Grid.ColumnSpan="2"/>
    </Grid>
</UserControl>