<UserControl x:Class="PBL3a.UI.AdminTC.LuongGV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Mã GV -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Mã GV:"
                   VerticalAlignment="Center"
                   FontSize="15"/>

        <ComboBox x:Name="cbbMGV"
                  Grid.Row="0" Grid.Column="1"
                  IsEditable="True"
                  VerticalAlignment="Center"
                  SelectionChanged="cbbMGV_SelectionChanged"
                  KeyUp="cbbMGV_KeyUp"/>

        <!-- Tên GV -->
        <TextBlock Grid.Row="0" Grid.Column="2"
                   Text="Tên GV:"
                   VerticalAlignment="Center"
                   FontSize="15"/>

        <TextBox x:Name="tbTL"
                 Grid.Row="0" Grid.Column="3"
                 IsReadOnly="True"/>

        <!-- Tháng -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Tháng:"
                   VerticalAlignment="Center"/>

        <ComboBox x:Name="cbbThang"
                  Grid.Row="1" Grid.Column="1">
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
            <ComboBoxItem Content="6"/>
            <ComboBoxItem Content="7"/>
            <ComboBoxItem Content="8"/>
            <ComboBoxItem Content="9"/>
            <ComboBoxItem Content="10"/>
            <ComboBoxItem Content="11"/>
            <ComboBoxItem Content="12"/>
        </ComboBox>

        <!-- Năm -->
        <TextBlock Grid.Row="1" Grid.Column="2"
                   Text="Năm:"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="txtNam"
                 Grid.Row="1" Grid.Column="3"/>

        <!-- Data -->
        <DataGrid x:Name="dataGridView1"
                  Grid.Row="2"
                  Grid.ColumnSpan="5"
                  AutoGenerateColumns="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  CellEditEnding="dataGridView1_CellEditEnding"/>

        <!-- Button -->
        <Button x:Name="btSetL"
                Grid.Row="3"
                Grid.Column="4"
                Content="Tính toán lương"
                Height="60"
                Background="#5D9CB3"
                Foreground="White"
                Click="btSetL_Click"/>
    </Grid>
</UserControl>