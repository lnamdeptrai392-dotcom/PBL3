<UserControl x:Class="PBL3a.UI.AdminTC.HocPhi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Mã Lớp:"
                   Foreground="Black"
                   FontSize="16"
                   VerticalAlignment="Center"/>

        <ComboBox x:Name="cbbML"
                  Grid.Row="0"
                  Grid.Column="1"
                  Height="35"
                  IsEditable="True"
                  IsTextSearchEnabled="False"
                  VerticalAlignment="Center"
                  SelectionChanged="cbbML_SelectionChanged"
                  KeyUp="cbbML_KeyUp"/>

        <TextBlock Grid.Row="0"
                   Grid.Column="2"
                   Text="Tên Lớp:"
                   Foreground="Black"
                   FontSize="16"
                   VerticalAlignment="Center"
                   Margin="20,0,0,0"/>

        <TextBox x:Name="tbTL"
                 Grid.Row="0"
                 Grid.Column="3"
                 Height="35"
                 IsReadOnly="True"
                 VerticalAlignment="Center"/>

        <DataGrid x:Name="dataGridView1"
                  Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="4"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Background="White"
                  Foreground="Black"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  Margin="0,10,0,10"/>

        <Button x:Name="btSetHP"
                Grid.Row="2"
                Grid.Column="3"
                Content="Thiết lập học phí"
                Width="180"
                Height="50"
                HorizontalAlignment="Right"
                Background="#5D9CB3"
                Foreground="White"
                FontSize="15"
                BorderThickness="0"
                Click="btSetHP_Click"/>
    </Grid>
</UserControl>