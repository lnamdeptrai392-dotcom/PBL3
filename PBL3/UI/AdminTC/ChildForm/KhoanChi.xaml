<UserControl x:Class="PBL3a.UI.AdminTC.KhoanChi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Ngày:"
                   FontSize="16"
                   Foreground="Black"
                   VerticalAlignment="Center"/>

        <DatePicker x:Name="ngay"
                    Grid.Row="0"
                    Grid.Column="1"
                    Height="35"
                    VerticalAlignment="Center"/>

        <TextBlock Grid.Row="0"
                   Grid.Column="2"
                   Text="Chi trong:"
                   FontSize="16"
                   Foreground="Black"
                   VerticalAlignment="Center"
                   Margin="20,0,0,0"/>

        <ComboBox x:Name="cbbC"
                  Grid.Row="0"
                  Grid.Column="3"
                  Height="35"
                  VerticalAlignment="Center">
            <ComboBoxItem Content="ngày"/>
            <ComboBoxItem Content="tháng"/>
            <ComboBoxItem Content="năm"/>
        </ComboBox>

        <Button x:Name="btOK"
                Grid.Row="0"
                Grid.Column="5"
                Content="OK"
                Height="40"
                Background="#5D9CB3"
                Foreground="White"
                FontSize="16"
                BorderThickness="0"
                Click="btOK_Click"/>

        <DataGrid x:Name="dataGridView1"
                  Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="6"
                  AutoGenerateColumns="True"
                  CanUserAddRows="True"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="Cell"
                  GridLinesVisibility="All"
                  HeadersVisibility="All"
                  Background="White"
                  Foreground="Black"
                  Margin="0,15,0,15"
                  CellEditEnding="dataGridView1_CellEditEnding"
                  BeginningEdit="dataGridView1_BeginningEdit"/>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Tổng:"
                   FontSize="16"
                   Foreground="Black"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="tbKT"
                 Grid.Row="2"
                 Grid.Column="1"
                 Grid.ColumnSpan="4"
                 Height="35"
                 IsReadOnly="True"
                 VerticalAlignment="Center"/>
    </Grid>
</UserControl>