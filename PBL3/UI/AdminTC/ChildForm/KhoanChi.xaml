<UserControl x:Class="PBL3a.UI.AdminTC.KhoanChi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" Height="500" Width="750">

    <Grid Margin="20,20,23,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="138"/>
            <ColumnDefinition Width="244"/>


        </Grid.ColumnDefinitions>

        <TextBlock
                   Grid.Column="0"
                   Text="Tháng:"
                   FontSize="16"
                   Foreground="Black"
                   VerticalAlignment="Center" Height="22"/>

        <ComboBox x:Name="cbbThang" SelectionChanged="Filter_Changed"
          Grid.Row="0" Grid.Column="1" BorderBrush="White" Foreground="Black" Margin="0,12,0,10" >
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
            <ComboBoxItem Content="6"/>
            <ComboBoxItem Content="7"/>
            <ComboBoxItem Content="8"/>
            <ComboBoxItem Content="9"/>
            <ComboBoxItem Content="10"/>
            <ComboBoxItem Content="11"/>
            <ComboBoxItem Content="12"/>
        </ComboBox>

        <TextBlock
                   Grid.Column="2"
                   Text="Năm:"
                   FontSize="16"
                   Foreground="Black"
                   VerticalAlignment="Center"
                   Margin="69,0,10,0" Height="22"/>

        <ComboBox x:Name="cbbNam" SelectionChanged="Filter_Changed"
                  Grid.Column="3"
                  Height="36"
                  VerticalAlignment="Center" Margin="14,0,16,0">
            <ComboBoxItem Content="2025"/>
            <ComboBoxItem Content="2026"/>
        </ComboBox>

        <Button x:Name="btnSave"
                Grid.Row="2"
                Grid.Column="3"
                Content="Lưu thay đổi"
                Background="#5D9CB3"
                Foreground="White"
                FontSize="16"
                BorderThickness="0"
                Click="btnSave_Click" Margin="80,15,16,15"/>

        <DataGrid x:Name="dataGridView1"
            Grid.Row="1"
            Grid.ColumnSpan="4"
            AutoGenerateColumns="False"
            SelectionMode="Single"
            CanUserAddRows="True"
            SelectionUnit="FullRow" Margin="10,10,0,0" HorizontalAlignment="Left" Width="696">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Chi" Binding="{Binding ChiID}" Width="60"/>
                <DataGridTextColumn Header="Loại chi" Binding="{Binding LoaiChi}" Width="120"/>
                <DataGridTextColumn Header="Nội dung" Binding="{Binding NoiDung}" Width="150"/>
                <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTien, StringFormat={}{0:N0} VNĐ}" Width="100"/>
                <DataGridTextColumn Header="Ngày chi" Binding="{Binding NgayChi}" Width="120"/>
                <DataGridTextColumn Header="Ghi chú" Binding="{Binding NoiDung}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Tổng chi:"
                   FontSize="16"
                   Foreground="Black"
                   VerticalAlignment="Center" Height="22"/>

        <TextBox x:Name="tbKT"
                 Grid.Row="2"
                 Grid.Column="1"
                 Height="34"
                 IsReadOnly="True"
                 Background="LightGray"
                 VerticalAlignment="Center"/>
        <Button x:Name="btnAdd" Click="btnAdd_Click" Grid.Column="2" Content="Them du lieu" HorizontalAlignment="Left" Margin="59,9,0,0" Grid.Row="2" VerticalAlignment="Top" Grid.ColumnSpan="2" Height="43" Width="107"
                Background="#5D9CB3"
                Foreground="White"
                FontSize="16"/> 
    </Grid>
</UserControl>