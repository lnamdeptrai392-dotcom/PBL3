<Window x:Class="PBL3a.UI.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Width="1000" Height="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#F4F7F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Grid Background="#2C4E62">
            <Image Source="/Resources/2026.png"
                   Width="180" Height="160"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
        </Grid>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1" Background="White">
            <StackPanel Width="370" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- TITLE -->
                <TextBlock Text="Đăng nhập"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A2F3A"
                           Margin="0 0 0 30"/>

                <!-- USERNAME -->
                <TextBlock Text="Tên đăng nhập:"
                           FontWeight="SemiBold"
                           Foreground="#1A2F3A"/>
                <TextBox x:Name="txtUsername"
                         Height="35"
                         Margin="0 5 0 15"/>

                <!-- PASSWORD -->
                <TextBlock Text="Mật khẩu:"
                           FontWeight="SemiBold"
                           Foreground="#1A2F3A"/>

                <Grid>
                    <PasswordBox x:Name="txtPassword"
                                 Height="35"/>
                    <TextBox x:Name="txtPasswordVisible"
                             Height="35"
                             Visibility="Collapsed"/>
                </Grid>

                <!-- OPTIONS -->
                <Grid Margin="0 10 0 20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="chkShowPassword"
                                Content="Hiện mật khẩu"
                                Checked="chkShowPassword_Checked"
                                Unchecked="chkShowPassword_Unchecked"/>

                    <TextBlock Text="Quên mật khẩu?"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               Foreground="Gray"
                               Cursor="Hand"/>
                </Grid>

                <!-- LOGIN BUTTON -->
                <Button Content="Đăng nhập"
                        Height="40"
                        Background="#5D9CB3"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="btnLogin_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>