<Window x:Class="PBL3a.UI.AdminC.AdminC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Quản Lý Chung"
        WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="#7092BE">
            <Button x:Name="btnHome" Height="107" Content="HOME"/>

            <Button x:Name="btnDuyetDon"
                    Height="107"
                    Content="     Duyệt Đơn"
                    Click="btnDuyetDon_Click"/>

            <Button x:Name="btnKhoaLop"
                    Height="107"
                    Content="     Thông Tin Khóa/Lớp"
                    Click="btnKhoaLop_Click"/>

            <Button x:Name="btnTaoTK"
                    Height="107"
                    Content="     Tạo Tài Khoản"
                    Click="btnTaoTK_Click"/>

            <Button x:Name="btnTaoLH"
                    Height="107"
                    Content="     Tạo Thêm Lớp Học"
                    Click="btnTaoLH_Click"/>

            <Button x:Name="butOut"
                    Height="107"
                    Content="     Đăng Xuất"
                    Click="butOut_Click"/>
        </StackPanel>

        <ContentControl x:Name="panelDesktop"
                        Grid.Column="1"/>
    </Grid>
</Window>