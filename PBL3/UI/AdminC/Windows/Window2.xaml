<UserControl x:Class="PBL3a.UI.AdminC.Windows.Window2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FILTER -->
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="Môn học:" Margin="10"/>
                <ComboBox x:Name="cbbMH" Width="150"
                          SelectionChanged="cbbMH_SelectionChanged"/>

                <TextBlock Text="Khối:" Margin="10"/>
                <ComboBox x:Name="cbbKhoi" Width="150"/>

                <TextBlock Text="Số lượng:" Margin="10"/>
                <TextBox x:Name="txtSL" Width="100"/>

                <TextBlock Text="Ngày mở:" Margin="10"/>
                <DatePicker x:Name="dtpNgayMo" Width="150"/>
            </StackPanel>

            <!-- TABLE -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="dgvGV"
                          Grid.Column="0"
                          AutoGenerateColumns="True"
                          SelectionChanged="dgvGV_SelectionChanged"/>

                <DataGrid x:Name="dgvTTGV"
                          Grid.Column="1"
                          AutoGenerateColumns="True"/>
            </Grid>

            <!-- BUTTON -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Tạo lớp học"
                        Width="200"
                        Margin="10"
                        Click="btnOK_Click"/>

                <Button Content="Lưu DB"
                        Width="200"
                        Margin="10"
                        Click="btnDB_Click"/>
            </StackPanel>

            <!-- TEMP TABLE -->
            <DataGrid x:Name="dgvLH"
                      Grid.Row="4"
                      Height="150"
                      Margin="0 20"
                      AutoGenerateColumns="True"/>
        </Grid>
    </ScrollViewer>
</UserControl>