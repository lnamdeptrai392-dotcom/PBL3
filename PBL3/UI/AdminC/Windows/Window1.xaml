<UserControl x:Class="PBL3a.UI.AdminC.Windows.Window1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F8FB">

    <UserControl.Resources>

        <!-- Button an toàn, không làm mất Click -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E88E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Padding" Value="8 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
            <Setter Property="ColumnWidth" Value="*"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E3EEF7"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E3EEF7"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0E3F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#0D47A1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER -->
            <Border Background="White"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#D6E6F2"
                    BorderThickness="1"
                    Margin="0 0 0 16">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Môn học"
                               Margin="0 0 8 0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbbMH"
                              SelectionChanged="cbbMH_SelectionChanged"/>

                    <TextBlock Text="Khối"
                               Margin="18 0 8 0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbbKhoi"
                              SelectionChanged="cbbKhoi_SelectionChanged"/>

                    <TextBlock Text="Lớp"
                               Margin="18 0 8 0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbbLop"/>

                    <Border CornerRadius="10"
                            Margin="18 0 0 0"
                            ClipToBounds="True">
                        <Button Content="Xem"
                                Width="90"
                                Click="btnView_Click"/>
                    </Border>

                </StackPanel>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT -->
                <Border Background="White"
                        CornerRadius="14"
                        Padding="14"
                        BorderBrush="#D6E6F2"
                        BorderThickness="1"
                        Margin="0 0 12 0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Danh sách đơn xin"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#0D47A1"
                                   Margin="0 0 0 10"/>

                        <DataGrid x:Name="dgvDonXin"
                                  Grid.Row="1"
                                  MinHeight="400"
                                  SelectionChanged="dgvDonXin_SelectionChanged"/>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0 12 0 0">

                            <Border CornerRadius="10"
                                    ClipToBounds="True"
                                    Margin="5">
                                <Button Content="Đồng ý"
                                        Width="110"
                                        Background="#1E88E5"
                                        Click="btnDongY_Click"/>
                            </Border>

                            <Border CornerRadius="10"
                                    ClipToBounds="True"
                                    Margin="5">
                                <Button Content="Từ chối"
                                        Width="110"
                                        Background="#EF5350"
                                        Click="btnTuChoi_Click"/>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="14"
                        Padding="14"
                        BorderBrush="#D6E6F2"
                        BorderThickness="1"
                        Margin="12 0 0 0">

                    <StackPanel>

                        <TextBlock Text="Thông Tin Học Sinh"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0D47A1"
                                   Margin="0 0 0 8"/>

                        <DataGrid x:Name="dgvTTHS"
                                  Height="150"/>

                        <TextBlock Text="Thông Tin Lớp Học"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0D47A1"
                                   Margin="0 16 0 8"/>

                        <DataGrid x:Name="dgvTTLH"
                                  Height="150"/>

                        <TextBlock Text="Lịch sử học"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0D47A1"
                                   Margin="0 16 0 8"/>

                        <DataGrid x:Name="dgvHS1"
                                  Height="160"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>