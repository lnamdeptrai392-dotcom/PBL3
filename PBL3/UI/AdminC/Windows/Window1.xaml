<UserControl x:Class="PBL3a.UI.AdminC.Windows.Window1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER -->
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="Môn học" Margin="10"/>
                <ComboBox x:Name="cbbMH" Width="150" SelectionChanged="cbbMH_SelectionChanged"/>

                <TextBlock Text="Khối" Margin="10"/>
                <ComboBox x:Name="cbbKhoi" Width="150" SelectionChanged="cbbKhoi_SelectionChanged"/>

                <TextBlock Text="Lớp" Margin="10"/>
                <ComboBox x:Name="cbbLop" Width="150"/>

                <Button Content="Xem"
                        Width="80"
                        Margin="10"
                        Click="btnView_Click"/>
            </StackPanel>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT TABLE -->
                <StackPanel>
                    <DataGrid x:Name="dgvDonXin"
                              AutoGenerateColumns="True"
                              Height="400"
                              SelectionChanged="dgvDonXin_SelectionChanged"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Đồng ý"
                                Width="100"
                                Margin="5"
                                Click="btnDongY_Click"/>

                        <Button Content="Từ chối"
                                Width="100"
                                Margin="5"
                                Click="btnTuChoi_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT INFO -->
                <StackPanel Grid.Column="1" Margin="10">

                    <TextBlock Text="Thông Tin Học Sinh" FontWeight="Bold"/>
                    <DataGrid x:Name="dgvTTHS"
                              AutoGenerateColumns="True"
                              HeadersVisibility="None"
                              Height="150"/>

                    <TextBlock Text="Thông Tin Lớp Học" FontWeight="Bold" Margin="0 10"/>
                    <DataGrid x:Name="dgvTTLH"
                              AutoGenerateColumns="True"
                              HeadersVisibility="None"
                              Height="150"/>

                    <TextBlock Text="Lịch sử học" FontWeight="Bold" Margin="0 10"/>
                    <DataGrid x:Name="dgvHS1"
                              AutoGenerateColumns="True"
                              Height="150"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>