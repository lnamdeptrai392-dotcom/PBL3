<UserControl x:Class="PBL3a.UI.AdminC.Windows.Window5"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="30">

            <TextBlock Text="Tạo tài khoản"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Vai trò:" Width="120"/>
                <ComboBox x:Name="cbbRole" Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="Họ tên:" Width="120"/>
                <TextBox x:Name="txtFullName" Width="300"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="Ngày sinh:" Width="120"/>
                <DatePicker x:Name="dtpDOB" Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="SĐT:" Width="120"/>
                <TextBox x:Name="txtPhone" Width="300"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="Giới tính:" Width="120"/>
                <RadioButton x:Name="rdoNam" Content="Nam" Margin="10 0"/>
                <RadioButton x:Name="rdoNu" Content="Nữ"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 20">
                <Button Content="Tạo"
                        Width="120"
                        Margin="10"
                        Click="btnTao_Click"/>

                <Button Content="Refresh"
                        Width="120"
                        Margin="10"
                        Click="btnRefresh_Click"/>
            </StackPanel>

            <DataGrid x:Name="dgvData"
                      Height="120"
                      AutoGenerateColumns="True"
                      Margin="0 10"/>

            <Button Content="Thêm vào DB"
                    Width="200"
                    HorizontalAlignment="Center"
                    Margin="10"
                    Click="btnThemDB_Click"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>