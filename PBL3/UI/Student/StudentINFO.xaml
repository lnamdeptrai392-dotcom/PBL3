<UserControl x:Class="PBL3a.UI.Student.StudentINFO"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="125"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="76"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="71"/>
            <RowDefinition Height="51"/>
            <RowDefinition Height="51"/>
            <RowDefinition Height="54"/>
            <RowDefinition Height="64"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="43"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="2"
                   Text="Thông tin cá nhân"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="1" Text="Họ tên:" FontSize="16" VerticalAlignment="Center"/>
        <TextBox x:Name="txtHoTen" Grid.Row="1" Grid.Column="2" Height="28" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="1" Text="Ngày sinh:" FontSize="16" VerticalAlignment="Center"/>
        <DatePicker x:Name="dtpNgaySinh" Grid.Row="2" Grid.Column="2" Height="30" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="3" Grid.Column="1" Text="Giới tính:" FontSize="16" VerticalAlignment="Center"/>
        <ComboBox x:Name="cboGioiTinh" Grid.Row="3" Grid.Column="2" Height="30" VerticalAlignment="Center">
            <ComboBoxItem Content="Nam"/>
            <ComboBoxItem Content="Nữ"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="1" Text="Email:" FontSize="16" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="4" Grid.Column="2" Height="28" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="5" Grid.Column="1" Text="SĐT:" FontSize="16" VerticalAlignment="Center"/>
        <TextBox x:Name="txtSDT" Grid.Row="5" Grid.Column="2" Height="28" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="6" Grid.Column="1" Text="Địa chỉ:" FontSize="16" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDiaChi" Grid.Row="6" Grid.Column="2" Height="28" VerticalAlignment="Center"/>

        <Button x:Name="btn_update"
                Grid.Row="7"
                Grid.Column="2"
                Content="Cập nhật"
                Width="119"
                Height="42"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="btn_update_Click"/>
    </Grid>
</UserControl>