<Window x:Class="PBL3a.UI.Student.StudentAll"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sinh viên Dashboard"
        Width="1000"
        Height="500"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="White">

    <Grid>
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#2C4E62"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#3E6A83"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="196"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Background="#FF263F60">

            <Border Background="#263f60" Height="80">
                <TextBlock Text="EduCore"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
            </Border>

            <Button x:Name="btn_info"
                    Content="   Thông tin cá nhân"
                    Height="60"
                    Click="btn_info_Click_1" Background="#FF263F60" HorizontalAlignment="Left"/>

            <Button x:Name="btn_schedule"
                    Content="   Thời khóa biểu"
                    Height="60"
                    Click="btn_schedule_Click" Background="#FF263F60" HorizontalAlignment="Left"/>

            <Button x:Name="btn_score"
                    Content="   Kết quả học tập"
                    Height="60"
                    Click="btn_score_Click" Background="#FF263F60" HorizontalAlignment="Left"/>

            <Button x:Name="btn_fee"
                    Content="   Học phí"
                    Height="60"
                    
                    Click="btn_fee_Click" Background="#FF263F60" HorizontalAlignment="Left"/>

            <Button x:Name="btn_exit"
                    Content="   Đăng xuất"
                    Height="60"
                    Click="btn_exit_Click" Background="#FF263F60" HorizontalAlignment="Left"/>
        </StackPanel>

        <ContentControl x:Name="panelChildBox"
                        Grid.Column="1"
                        Background="White"/>
    </Grid>
</Window>